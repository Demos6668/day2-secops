# Day2 SecOps — environment template
# All real values are mocked in v1. The webhook seam talks to a SERVER, not OEMs directly.

# Vite dev server
VITE_PORT=5174
BASE_PATH=/

# Default workspace (matches workspaces/<id>.json). Switchable in the UI.
VITE_WORKSPACE_ID=abcl

# Same-origin Day2 SecOps API base. The frontend polls this; the server is
# where HMAC verification and per-OEM circuit breakers live.
VITE_API_BASE=/api

# Day2 OSINT sister-service launcher URL (Vuln Mgmt → OSINT page).
# Only http: and https: protocols are accepted; anything else is rejected.
# Leave at localhost during local dev; set to the real OSINT origin in prod.
VITE_DAY2_OSINT_URL=https://osint.example.com

# Optional: per-deployment logo.dev token. If unset, a publishable token
# baked into the bundle is used (publishable-class, safe to ship client-side).
# VITE_LOGO_DEV_TOKEN=pk_your_publishable_token

# ─────────────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY. Do NOT prefix these VITE_* — Vite would inline them
# into the public bundle, defeating any signing scheme. These live in the
# Day2 SecOps API service environment, never in the browser.
# ─────────────────────────────────────────────────────────────────────────
# WEBHOOK_URL_mfa=https://your.internal/visibility/mfa
# WEBHOOK_SECRET_mfa=change-me
# WEBHOOK_URL_appTrana=https://your.internal/visibility/appTrana
# WEBHOOK_SECRET_appTrana=change-me

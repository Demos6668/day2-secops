{
  "name": "day2-secops-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Day2 SecOps backend — webhook receiver, snapshot store, admin API, WebSocket bus.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.5.13",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  }
}
